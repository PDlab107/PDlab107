{% comment %}
  SEO Meta Tags
{% endcomment %}

{%- assign og_title = page_title -%}
{%- assign og_description = page_description | default: shop.description -%}
{%- assign og_url = canonical_url -%}
{%- assign og_type = 'website' -%}
{%- assign og_image = '' -%}

{%- if template contains 'product' -%}
  {%- assign og_type = 'product' -%}
  {%- if product.featured_image -%}
    {%- assign og_image = product.featured_image | img_url: '1200x1200' -%}
  {%- endif -%}
{%- elsif template contains 'article' -%}
  {%- assign og_type = 'article' -%}
  {%- if article.image -%}
    {%- assign og_image = article.image | img_url: '1200x1200' -%}
  {%- endif -%}
{%- endif -%}

<!-- Primary Meta Tags -->
<meta name="title" content="{{ og_title }}">
<meta name="description" content="{{ og_description }}">
<meta name="keywords" content="denture repair, acrylic denture repair, denture repair by post, denture repair service, denture repair UK, broken denture repair, cracked denture repair, tooth replacement, denture services, postal denture repair">

<!-- Robots -->
<meta name="robots" content="index, follow">
<meta name="googlebot" content="index, follow">

<!-- Language and Region -->
<meta name="language" content="English">
<meta name="geo.region" content="GB">
<meta name="geo.placename" content="United Kingdom">

<!-- Author and Publisher -->
<meta name="author" content="{{ shop.name }}">
<meta name="publisher" content="{{ shop.name }}">

<!-- Schema.org markup for Google -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "{{ shop.name }}",
  "description": "{{ shop.description | escape }}",
  "url": "{{ shop.url }}",
  "telephone": "+44 123 456 7890",
  "email": "info@denturefixnow.co.uk",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "GB"
  },
  "priceRange": "££",
  "image": "{{ 'logo.png' | asset_url }}",
  "sameAs": []
}
</script>

{% if template == 'index' %}
<!-- FAQ Schema for Homepage -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long does denture repair take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most denture repairs are completed within 2-3 business days from when we receive your dentures. Express service is available for urgent repairs."
      }
    },
    {
      "@type": "Question",
      "name": "How do I ship my dentures securely?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We provide detailed packaging instructions and prepaid postage labels. Simply wrap your dentures in bubble wrap, place them in a sturdy box, and use our tracked shipping service."
      }
    },
    {
      "@type": "Question",
      "name": "How much does denture repair cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Prices start from £50 for basic repairs. The exact cost depends on the type of repair needed. We provide free quotes based on photos of your dentures."
      }
    }
  ]
}
</script>
{% endif %}

{% if template contains 'product' %}
<!-- Product Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ product.title | escape }}",
  "description": "{{ product.description | strip_html | escape }}",
  "image": "{{ product.featured_image | img_url: 'grande' }}",
  "url": "{{ shop.url }}{{ product.url }}",
  "offers": {
    "@type": "Offer",
    "price": "{{ product.price | money_without_currency }}",
    "priceCurrency": "{{ shop.currency }}",
    "availability": "https://schema.org/InStock",
    "url": "{{ shop.url }}{{ product.url }}"
  }
}
</script>
{% endif %}

{% if template contains 'article' %}
<!-- Article Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ article.title | escape }}",
  "description": "{{ article.excerpt_or_content | strip_html | truncate: 200 | escape }}",
  "image": "{{ article.image | img_url: 'grande' }}",
  "datePublished": "{{ article.published_at | date: '%Y-%m-%d' }}",
  "dateModified": "{{ article.updated_at | date: '%Y-%m-%d' }}",
  "author": {
    "@type": "Person",
    "name": "{{ article.author }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ shop.name }}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ 'logo.png' | asset_url }}"
    }
  }
}
</script>
{% endif %}

<!-- Breadcrumbs Schema -->
{% unless template == 'index' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ shop.url }}"
    }
    {% if template contains 'page' %}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "{{ page.title }}",
      "item": "{{ shop.url }}{{ page.url }}"
    }
    {% elsif template contains 'product' %}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "{{ product.title }}",
      "item": "{{ shop.url }}{{ product.url }}"
    }
    {% elsif template contains 'article' %}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": "{{ shop.url }}{{ blog.url }}"
    }
    ,{
      "@type": "ListItem",
      "position": 3,
      "name": "{{ article.title }}",
      "item": "{{ shop.url }}{{ article.url }}"
    }
    {% endif %}
  ]
}
</script>
{% endunless %}
