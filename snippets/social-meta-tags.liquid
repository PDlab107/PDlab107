{% comment %}
  Social Media Meta Tags (Open Graph and Twitter Cards)
{% endcomment %}

{%- assign og_title = page_title -%}
{%- assign og_description = page_description | default: shop.description -%}
{%- assign og_url = canonical_url -%}
{%- assign og_type = 'website' -%}
{%- assign og_image = '' -%}

{%- if template contains 'product' -%}
  {%- assign og_type = 'product' -%}
  {%- if product.featured_image -%}
    {%- assign og_image = product.featured_image | img_url: '1200x1200' | prepend: 'https:' -%}
  {%- endif -%}
{%- elsif template contains 'article' -%}
  {%- assign og_type = 'article' -%}
  {%- if article.image -%}
    {%- assign og_image = article.image | img_url: '1200x1200' | prepend: 'https:' -%}
  {%- endif -%}
{%- endif -%}

<!-- Open Graph / Facebook -->
<meta property="og:type" content="{{ og_type }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title }}">
<meta property="og:description" content="{{ og_description }}">
<meta property="og:site_name" content="{{ shop.name }}">
{% if og_image != blank %}
<meta property="og:image" content="{{ og_image }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="1200">
{% endif %}
<meta property="og:locale" content="en_GB">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:url" content="{{ og_url }}">
<meta name="twitter:title" content="{{ og_title }}">
<meta name="twitter:description" content="{{ og_description }}">
{% if og_image != blank %}
<meta name="twitter:image" content="{{ og_image }}">
{% endif %}

{% if template contains 'product' %}
<!-- Product-specific meta tags -->
<meta property="product:price:amount" content="{{ product.price | money_without_currency }}">
<meta property="product:price:currency" content="{{ shop.currency }}">
<meta property="product:availability" content="in stock">
{% endif %}
