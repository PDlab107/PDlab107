{% comment %}
  Blog Template - Main blog listing page
{% endcomment %}

<div class="section section--large">
  <div class="container">
    <div class="section__header">
      <h1>{{ blog.title }}</h1>
      {% if blog.description != blank %}
        <p class="section__subtitle">{{ blog.description }}</p>
      {% else %}
        <p class="section__subtitle">Expert tips and advice for denture care and maintenance</p>
      {% endif %}
    </div>

    {% if blog.articles.size > 0 %}
      <div class="grid grid--2" style="gap: 3rem;">
        {% for article in blog.articles %}
          <article class="card" style="height: 100%;">
            {% if article.image %}
              <div style="margin: -2rem -2rem 1.5rem -2rem; border-radius: 12px 12px 0 0; overflow: hidden;">
                <img 
                  src="{{ article.image | img_url: '800x' }}" 
                  alt="{{ article.image.alt | escape }}"
                  style="width: 100%; height: 300px; object-fit: cover;"
                >
              </div>
            {% endif %}

            <div>
              <h2 class="card__title">
                <a href="{{ article.url }}" style="color: inherit; text-decoration: none;">
                  {{ article.title }}
                </a>
              </h2>

              <div style="display: flex; gap: 1rem; margin-bottom: 1rem; font-size: 1rem; color: var(--color-text-light);">
                <span>📅 {{ article.published_at | date: '%B %d, %Y' }}</span>
                <span>✍️ {{ article.author }}</span>
              </div>

              {% if article.excerpt != blank %}
                <p class="card__content">
                  {{ article.excerpt | strip_html | truncate: 200 }}
                </p>
              {% else %}
                <p class="card__content">
                  {{ article.content | strip_html | truncate: 200 }}
                </p>
              {% endif %}

              <a href="{{ article.url }}" class="btn btn--secondary" style="margin-top: 1rem;">
                Read More →
              </a>
            </div>
          </article>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div style="margin-top: 3rem; text-align: center;">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="btn btn--secondary">
              ← Previous
            </a>
          {% endif %}

          <span style="margin: 0 2rem; font-size: 1.125rem;">
            Page {{ paginate.current_page }} of {{ paginate.pages }}
          </span>

          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="btn btn--secondary">
              Next →
            </a>
          {% endif %}
        </div>
      {% endif %}

    {% else %}
      <div class="card text-center">
        <h2 class="card__title">No Articles Yet</h2>
        <p class="card__content">
          Check back soon for helpful tips and advice on denture care!
        </p>
      </div>
    {% endif %}

    <!-- Featured Topics -->
    <div class="card mt-3" style="background-color: var(--color-background-light);">
      <h2 class="card__title" style="text-align: center;">Popular Topics</h2>
      <div class="grid grid--4 mt-2">
        <div style="text-align: center; padding: 1rem;">
          <div style="font-size: 2.5rem; margin-bottom: 0.5rem;">🦷</div>
          <h3 style="font-size: 1.25rem;">Denture Care</h3>
        </div>
        <div style="text-align: center; padding: 1rem;">
          <div style="font-size: 2.5rem; margin-bottom: 0.5rem;">🔧</div>
          <h3 style="font-size: 1.25rem;">Repair Tips</h3>
        </div>
        <div style="text-align: center; padding: 1rem;">
          <div style="font-size: 2.5rem; margin-bottom: 0.5rem;">✨</div>
          <h3 style="font-size: 1.25rem;">Maintenance</h3>
        </div>
        <div style="text-align: center; padding: 1rem;">
          <div style="font-size: 2.5rem; margin-bottom: 0.5rem;">💡</div>
          <h3 style="font-size: 1.25rem;">Expert Advice</h3>
        </div>
      </div>
    </div>
  </div>
</div>
