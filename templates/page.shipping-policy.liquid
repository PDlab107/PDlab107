{% comment %}
  Shipping Policy Page Template
{% endcomment %}

<div class="section section--large">
  <div class="container container--narrow">
    <h1>Shipping Policy</h1>
    <p style="font-size: 1.125rem; color: var(--color-text-light); margin-bottom: 3rem;">
      Last updated: {{ 'now' | date: '%B %d, %Y' }}
    </p>

    <div class="card mb-2">
      <h2 class="card__title">Free Insured Shipping</h2>
      <p class="card__content">
        All our services include free, fully insured postage both ways. You won't pay extra for shipping – it's included in the service price.
      </p>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Shipping Your Dentures to Us</h2>
      <p class="card__content">
        <strong>Step 1: Order Online</strong><br>
        Place your order through our website and we'll send you a prepaid shipping label via email within 24 hours.
      </p>
      <p class="card__content">
        <strong>Step 2: Package Securely</strong><br>
        Follow our packaging instructions:
      </p>
      <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
        <li>Clean your dentures gently with water</li>
        <li>Wrap them in bubble wrap or soft cloth</li>
        <li>Place in a sturdy box or padded envelope</li>
        <li>Include your order number on a note inside</li>
        <li>Seal the package securely</li>
      </ul>
      <p class="card__content">
        <strong>Step 3: Ship</strong><br>
        Attach our prepaid label and drop off at your nearest post office or arrange collection.
      </p>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Delivery Times</h2>
      <p class="card__content">
        <strong>To Our Laboratory:</strong> 1-2 business days (UK mainland)<br>
        <strong>Repair Time:</strong> 2-3 business days<br>
        <strong>Return to You:</strong> 1-2 business days (UK mainland)
      </p>
      <p class="card__content" style="margin-top: 1.5rem;">
        <strong>Total Time:</strong> Typically 5-7 business days from posting to receiving your repaired dentures.
      </p>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Express Service</h2>
      <p class="card__content">
        Need your dentures back urgently? Our express service includes:
      </p>
      <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
        <li>Next-day repair processing</li>
        <li>Express shipping both ways</li>
        <li>Priority handling</li>
        <li>Total turnaround: 2-3 business days</li>
      </ul>
      <p class="card__content" style="margin-top: 1.5rem;">
        Express service costs an additional £20. Contact us to arrange.
      </p>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Tracking</h2>
      <p class="card__content">
        All shipments are tracked. You'll receive:
      </p>
      <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
        <li>Tracking number when we receive your dentures</li>
        <li>Confirmation when repair is complete</li>
        <li>Tracking number when we ship back to you</li>
        <li>Real-time tracking updates via email</li>
      </ul>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Insurance</h2>
      <p class="card__content">
        Every shipment is fully insured for the value of your dentures and repair service. In the unlikely event of loss or damage during shipping:
      </p>
      <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
        <li>Report it to us immediately</li>
        <li>We'll file an insurance claim</li>
        <li>You'll be compensated for the full value</li>
        <li>No additional cost to you</li>
      </ul>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Home Collection Service</h2>
      <p class="card__content">
        Can't get to the post office? We offer a home collection service for an additional £10. The courier will:
      </p>
      <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
        <li>Collect your dentures from your home</li>
        <li>Provide secure packaging</li>
        <li>Ensure safe delivery to our laboratory</li>
      </ul>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Delivery Areas</h2>
      <p class="card__content">
        <strong>UK Mainland:</strong> All areas covered with standard delivery times<br>
        <strong>Scottish Highlands & Islands:</strong> May take 1-2 additional days<br>
        <strong>Northern Ireland:</strong> Standard delivery times apply<br>
        <strong>International:</strong> Contact us for availability and shipping times
      </p>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Packaging Tips</h2>
      <p class="card__content">
        To ensure your dentures arrive safely:
      </p>
      <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
        <li>Use plenty of cushioning material</li>
        <li>Ensure the package is rigid and won't bend</li>
        <li>Mark as "FRAGILE" if desired</li>
        <li>Include your contact information inside the package</li>
        <li>Keep the tracking number safe</li>
      </ul>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Contact Us</h2>
      <p class="card__content">
        Questions about shipping?
      </p>
      <p class="card__content">
        Email: <a href="mailto:shipping@denturefixnow.co.uk">shipping@denturefixnow.co.uk</a><br>
        Phone: <a href="tel:+441234567890">+44 123 456 7890</a>
      </p>
    </div>
  </div>
</div>
