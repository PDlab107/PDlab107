{% comment %}
  Pricing Page Template
{% endcomment %}

<div class="section section--large">
  <div class="container">
    <div class="section__header">
      <h1>Transparent Pricing</h1>
      <p class="section__subtitle">Clear, honest pricing with no hidden costs</p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid--3 mb-3">
      <!-- Basic Repair Package -->
      <div class="pricing-card">
        <h2 class="pricing-card__title">Basic Repair</h2>
        <div class="pricing-card__price">£50</div>
        <p class="pricing-card__period">Starting price</p>
        <ul class="pricing-card__features">
          <li class="pricing-card__feature">Crack or break repair</li>
          <li class="pricing-card__feature">Professional cleaning</li>
          <li class="pricing-card__feature">Polishing & sanitizing</li>
          <li class="pricing-card__feature">Free insured postage</li>
          <li class="pricing-card__feature">2-3 day turnaround</li>
          <li class="pricing-card__feature">Quality guarantee</li>
        </ul>
        <a href="/pages/services#cracked-repair" class="btn btn--primary" style="width: 100%;">
          Choose Basic
        </a>
      </div>

      <!-- Standard Package (Featured) -->
      <div class="pricing-card pricing-card--featured">
        <div class="pricing-card__badge">Most Popular</div>
        <h2 class="pricing-card__title">Standard Repair</h2>
        <div class="pricing-card__price">£85</div>
        <p class="pricing-card__period">Starting price</p>
        <ul class="pricing-card__features">
          <li class="pricing-card__feature">Everything in Basic</li>
          <li class="pricing-card__feature">Tooth replacement (1-2 teeth)</li>
          <li class="pricing-card__feature">Minor adjustments</li>
          <li class="pricing-card__feature">Deep cleaning</li>
          <li class="pricing-card__feature">Priority processing</li>
          <li class="pricing-card__feature">Extended warranty</li>
        </ul>
        <a href="/pages/contact" class="btn btn--primary" style="width: 100%;">
          Choose Standard
        </a>
      </div>

      <!-- Premium Package -->
      <div class="pricing-card">
        <h2 class="pricing-card__title">Premium Repair</h2>
        <div class="pricing-card__price">£120</div>
        <p class="pricing-card__period">Starting price</p>
        <ul class="pricing-card__features">
          <li class="pricing-card__feature">Everything in Standard</li>
          <li class="pricing-card__feature">Complete reline included</li>
          <li class="pricing-card__feature">Multiple tooth replacement</li>
          <li class="pricing-card__feature">Express 1-day service</li>
          <li class="pricing-card__feature">Personal technician</li>
          <li class="pricing-card__feature">Lifetime support</li>
        </ul>
        <a href="/pages/contact" class="btn btn--primary" style="width: 100%;">
          Choose Premium
        </a>
      </div>
    </div>

    <!-- Individual Services Pricing -->
    <div class="card mb-3">
      <h2 class="card__title" style="text-align: center;">Individual Service Pricing</h2>
      <p class="card__content" style="text-align: center; margin-bottom: 2rem;">
        Prefer to choose individual services? Here's our complete price list.
      </p>

      <div class="grid grid--2">
        <div style="background-color: var(--color-background-light); padding: 2rem; border-radius: 12px;">
          <h3 style="font-size: 1.75rem; margin-bottom: 1.5rem; color: var(--color-primary);">Repair Services</h3>
          
          <div style="display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid var(--color-border);">
            <span style="font-size: 1.125rem;">Simple crack repair</span>
            <span style="font-size: 1.125rem; font-weight: 600;">£50</span>
          </div>
          
          <div style="display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid var(--color-border);">
            <span style="font-size: 1.125rem;">Complex break repair</span>
            <span style="font-size: 1.125rem; font-weight: 600;">£75</span>
          </div>
          
          <div style="display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid var(--color-border);">
            <span style="font-size: 1.125rem;">Multiple crack repair</span>
            <span style="font-size: 1.125rem; font-weight: 600;">£90</span>
          </div>
          
          <div style="display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid var(--color-border);">
            <span style="font-size: 1.125rem;">Denture adjustments</span>
            <span style="font-size: 1.125rem; font-weight: 600;">£40</span>
          </div>
          
          <div style="display: flex; justify-content: space-between; padding: 1rem 0;">
            <span style="font-size: 1.125rem;">Emergency repair service</span>
            <span style="font-size: 1.125rem; font-weight: 600;">£150</span>
          </div>
        </div>

        <div style="background-color: var(--color-background-light); padding: 2rem; border-radius: 12px;">
          <h3 style="font-size: 1.75rem; margin-bottom: 1.5rem; color: var(--color-primary);">Additional Services</h3>
          
          <div style="display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid var(--color-border);">
            <span style="font-size: 1.125rem;">Single tooth replacement</span>
            <span style="font-size: 1.125rem; font-weight: 600;">£65</span>
          </div>
          
          <div style="display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid var(--color-border);">
            <span style="font-size: 1.125rem;">Multiple teeth (per tooth)</span>
            <span style="font-size: 1.125rem; font-weight: 600;">£55</span>
          </div>
          
          <div style="display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid var(--color-border);">
            <span style="font-size: 1.125rem;">Denture reline</span>
            <span style="font-size: 1.125rem; font-weight: 600;">£80</span>
          </div>
          
          <div style="display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid var(--color-border);">
            <span style="font-size: 1.125rem;">Professional cleaning</span>
            <span style="font-size: 1.125rem; font-weight: 600;">£35</span>
          </div>
          
          <div style="display: flex; justify-content: space-between; padding: 1rem 0;">
            <span style="font-size: 1.125rem;">Express service (add-on)</span>
            <span style="font-size: 1.125rem; font-weight: 600;">£20</span>
          </div>
        </div>
      </div>
    </div>

    <!-- What's Included -->
    <div class="card mb-3">
      <h2 class="card__title" style="text-align: center;">What's Included in Every Service</h2>
      <div class="grid grid--4 mt-2">
        <div style="text-align: center; padding: 1.5rem;">
          <div style="font-size: 3rem; margin-bottom: 1rem; color: var(--color-secondary);">✓</div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem;">Free Shipping</h3>
          <p style="font-size: 1rem; color: var(--color-text-light);">Fully insured postage both ways</p>
        </div>
        
        <div style="text-align: center; padding: 1.5rem;">
          <div style="font-size: 3rem; margin-bottom: 1rem; color: var(--color-secondary);">✓</div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem;">Professional Cleaning</h3>
          <p style="font-size: 1rem; color: var(--color-text-light);">Deep cleaning & sanitizing</p>
        </div>
        
        <div style="text-align: center; padding: 1.5rem;">
          <div style="font-size: 3rem; margin-bottom: 1rem; color: var(--color-secondary);">✓</div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem;">Quality Guarantee</h3>
          <p style="font-size: 1rem; color: var(--color-text-light);">30-day satisfaction promise</p>
        </div>
        
        <div style="text-align: center; padding: 1.5rem;">
          <div style="font-size: 3rem; margin-bottom: 1rem; color: var(--color-secondary);">✓</div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem;">Expert Technicians</h3>
          <p style="font-size: 1rem; color: var(--color-text-light);">Certified professionals</p>
        </div>
      </div>
    </div>

    <!-- No Hidden Costs -->
    <div class="card mb-3" style="background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border-left: 4px solid var(--color-secondary);">
      <h2 class="card__title" style="color: var(--color-secondary);">💰 No Hidden Costs Promise</h2>
      <p class="card__content" style="font-size: 1.25rem;">
        The price you see is the price you pay. We believe in complete transparency:
      </p>
      <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem; margin-top: 1rem;">
        <li><strong>No hidden fees</strong> – All costs are clearly stated upfront</li>
        <li><strong>No surprise charges</strong> – We'll contact you before any additional work</li>
        <li><strong>Free shipping</strong> – Fully insured postage included in all prices</li>
        <li><strong>Free quotes</strong> – Get an accurate estimate before you commit</li>
        <li><strong>Price match guarantee</strong> – We'll beat any legitimate competitor quote</li>
      </ul>
    </div>

    <!-- FAQ Section -->
    <div class="card mb-3">
      <h2 class="card__title" style="text-align: center;">Pricing FAQs</h2>
      
      <div class="faq">
        <div class="faq-item">
          <div class="faq-question">
            How do I know the exact cost before sending my dentures?
            <span class="faq-icon">+</span>
          </div>
          <div class="faq-answer">
            Simply upload photos of your dentures and describe the problem. We'll provide a free, detailed quote within 24 hours. You'll know the exact cost before sending anything.
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            Is shipping really free?
            <span class="faq-icon">+</span>
          </div>
          <div class="faq-answer">
            Yes! All our prices include fully insured, tracked postage both ways. You won't pay extra for shipping unless you request home collection service.
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            What if my dentures need more work than expected?
            <span class="faq-icon">+</span>
          </div>
          <div class="faq-answer">
            We'll always contact you before doing any additional work. You'll receive a revised quote and can choose to proceed or have your dentures returned at no extra cost.
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            Do you offer payment plans?
            <span class="faq-icon">+</span>
          </div>
          <div class="faq-answer">
            For repairs over £100, we can arrange flexible payment plans. Contact us to discuss options that suit your budget.
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            What's included in the express service?
            <span class="faq-icon">+</span>
          </div>
          <div class="faq-answer">
            Express service prioritizes your repair for next-day completion. It includes expedited shipping both ways and priority handling by our technicians. Add £20 to any service.
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-question">
            Do you price match?
            <span class="faq-icon">+</span>
          </div>
          <div class="faq-answer">
            Yes! If you find a lower price for the same service from a legitimate UK-based competitor, we'll match it and give you an additional 5% discount.
          </div>
        </div>
      </div>
    </div>

    <!-- Discounts and Offers -->
    <div class="card mb-3">
      <h2 class="card__title" style="text-align: center;">Special Offers & Discounts</h2>
      <div class="grid grid--3 mt-2">
        <div style="background-color: #fef3c7; padding: 2rem; border-radius: 12px; text-align: center;">
          <div style="font-size: 3rem; margin-bottom: 1rem;">🎉</div>
          <h3 style="font-size: 1.5rem; margin-bottom: 1rem; color: #d97706;">First-Time Customer</h3>
          <p style="font-size: 1.125rem; margin-bottom: 1rem;">10% off your first order</p>
          <p style="font-size: 1rem; color: var(--color-text-light);">Use code: FIRST10</p>
        </div>
        
        <div style="background-color: #dbeafe; padding: 2rem; border-radius: 12px; text-align: center;">
          <div style="font-size: 3rem; margin-bottom: 1rem;">👴</div>
          <h3 style="font-size: 1.5rem; margin-bottom: 1rem; color: #2563eb;">Senior Discount</h3>
          <p style="font-size: 1.125rem; margin-bottom: 1rem;">15% off for over 65s</p>
          <p style="font-size: 1rem; color: var(--color-text-light);">Automatically applied</p>
        </div>
        
        <div style="background-color: #f3e8ff; padding: 2rem; border-radius: 12px; text-align: center;">
          <div style="font-size: 3rem; margin-bottom: 1rem;">💝</div>
          <h3 style="font-size: 1.5rem; margin-bottom: 1rem; color: #7c3aed;">Referral Bonus</h3>
          <p style="font-size: 1.125rem; margin-bottom: 1rem;">£10 off per referral</p>
          <p style="font-size: 1rem; color: var(--color-text-light);">Refer friends & save</p>
        </div>
      </div>
    </div>

    <div class="text-center mt-3">
      <h2 style="margin-bottom: 1.5rem;">Ready to Get Started?</h2>
      <p style="font-size: 1.25rem; margin-bottom: 2rem;">
        Get your free quote today
      </p>
      <a href="/pages/contact" class="btn btn--primary btn--large" style="margin-right: 1rem;">
        Get Free Quote
      </a>
      <a href="/pages/services" class="btn btn--secondary btn--large">
        View Services
      </a>
    </div>
  </div>
</div>
