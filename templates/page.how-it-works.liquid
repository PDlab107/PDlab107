{% comment %}
  How It Works Page Template
{% endcomment %}

<div class="section section--large">
  <div class="container">
    <div class="section__header">
      <h1>How Our Denture Repair Service Works</h1>
      <p class="section__subtitle">A simple, secure, and hassle-free process from start to finish</p>
    </div>

    <!-- Main Steps -->
    <div class="steps mb-3">
      <div class="step">
        <div class="step__number">1</div>
        <h2 class="step__title">Order Online</h2>
        <p class="step__description">
          Browse our services and select the repair you need. Upload photos of your dentures for a free, no-obligation quote. Once you're happy with the price, proceed with your order.
        </p>
      </div>

      <div class="step">
        <div class="step__number">2</div>
        <h2 class="step__title">Send Your Dentures</h2>
        <p class="step__description">
          Use our prepaid, fully insured postage service. We'll send you a secure packaging kit with detailed instructions. Simply pack your dentures and drop them at your nearest post office or arrange collection.
        </p>
      </div>

      <div class="step">
        <div class="step__number">3</div>
        <h2 class="step__title">We Repair</h2>
        <p class="step__description">
          Our expert technicians will repair, clean, polish, and sanitize your dentures. We'll keep you updated throughout the process and notify you when your dentures are ready to be shipped back.
        </p>
      </div>

      <div class="step">
        <div class="step__number">4</div>
        <h2 class="step__title">Receive Your Dentures</h2>
        <p class="step__description">
          Your professionally repaired dentures will be returned to you via tracked, insured delivery within 2-3 working days. Enjoy your restored smile!
        </p>
      </div>
    </div>

    <!-- Detailed Breakdown -->
    <div class="container container--narrow mt-3">
      <div class="card mb-3">
        <h2 class="card__title">Step 1: Ordering Online</h2>
        <p class="card__content">
          Getting started is easy:
        </p>
        <ol style="font-size: 1.125rem; line-height: 2; margin-left: 2rem; margin-top: 1rem;">
          <li><strong>Visit our Services page</strong> and select the type of repair you need</li>
          <li><strong>Upload clear photos</strong> of your dentures showing the damage (optional but recommended for accurate quotes)</li>
          <li><strong>Receive your free quote</strong> within 24 hours</li>
          <li><strong>Place your order</strong> securely through our website</li>
          <li><strong>Receive confirmation</strong> via email with your order details and next steps</li>
        </ol>
      </div>

      <div class="card mb-3">
        <h2 class="card__title">Step 2: Sending Your Dentures Safely</h2>
        <p class="card__content">
          We make it easy and secure:
        </p>
        <div class="grid grid--2 mt-2">
          <div>
            <h3 style="font-size: 1.5rem; margin-bottom: 1rem;">📦 Packaging Instructions</h3>
            <ul style="font-size: 1.125rem; line-height: 1.8; margin-left: 1.5rem;">
              <li>Clean your dentures gently</li>
              <li>Wrap them in bubble wrap or soft cloth</li>
              <li>Place in a sturdy box or padded envelope</li>
              <li>Include your order number</li>
              <li>Use our prepaid label</li>
            </ul>
          </div>
          <div>
            <h3 style="font-size: 1.5rem; margin-bottom: 1rem;">🔒 Safety & Insurance</h3>
            <ul style="font-size: 1.125rem; line-height: 1.8; margin-left: 1.5rem;">
              <li>Fully insured delivery both ways</li>
              <li>Tracked shipping for peace of mind</li>
              <li>Secure handling procedures</li>
              <li>Professional packaging materials included</li>
              <li>Real-time tracking updates</li>
            </ul>
          </div>
        </div>
        <p class="card__content mt-2">
          <strong>Can't get to the post office?</strong> We can arrange a collection from your home for an additional small fee.
        </p>
      </div>

      <div class="card mb-3">
        <h2 class="card__title">Step 3: Professional Repair Process</h2>
        <p class="card__content">
          Once your dentures arrive at our laboratory:
        </p>
        <div style="margin-top: 1.5rem;">
          <div style="padding: 1.5rem; background-color: var(--color-background-light); border-radius: 8px; margin-bottom: 1rem;">
            <h3 style="font-size: 1.5rem; margin-bottom: 0.75rem; color: var(--color-primary);">Day 1: Receipt & Assessment</h3>
            <p style="font-size: 1.125rem; line-height: 1.7;">
              We receive your dentures, send you a confirmation email, and conduct a thorough assessment. If any additional work is needed beyond your original order, we'll contact you for approval before proceeding.
            </p>
          </div>
          
          <div style="padding: 1.5rem; background-color: var(--color-background-light); border-radius: 8px; margin-bottom: 1rem;">
            <h3 style="font-size: 1.5rem; margin-bottom: 0.75rem; color: var(--color-primary);">Day 2: Repair Work</h3>
            <p style="font-size: 1.125rem; line-height: 1.7;">
              Our certified technicians perform the repairs using high-quality materials. This includes structural repairs, tooth replacements, relining, or any other services you've ordered.
            </p>
          </div>
          
          <div style="padding: 1.5rem; background-color: var(--color-background-light); border-radius: 8px; margin-bottom: 1rem;">
            <h3 style="font-size: 1.5rem; margin-bottom: 0.75rem; color: var(--color-primary);">Day 2-3: Finishing Touches</h3>
            <p style="font-size: 1.125rem; line-height: 1.7;">
              We clean, polish, and sanitize your dentures. Quality control checks ensure everything meets our high standards.
            </p>
          </div>
          
          <div style="padding: 1.5rem; background-color: var(--color-background-light); border-radius: 8px;">
            <h3 style="font-size: 1.5rem; margin-bottom: 0.75rem; color: var(--color-primary);">Day 3: Dispatch</h3>
            <p style="font-size: 1.125rem; line-height: 1.7;">
              Your dentures are carefully packaged and dispatched back to you via tracked, insured delivery. You'll receive a shipping notification with tracking details.
            </p>
          </div>
        </div>
      </div>

      <div class="card mb-3">
        <h2 class="card__title">Step 4: Receiving Your Dentures</h2>
        <p class="card__content">
          Your repaired dentures will be delivered to your door:
        </p>
        <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem; margin-top: 1rem;">
          <li><strong>Tracked delivery</strong> – You'll know exactly when to expect your dentures</li>
          <li><strong>Secure packaging</strong> – Protected during transit</li>
          <li><strong>Care instructions</strong> – Guidelines for maintaining your repaired dentures</li>
          <li><strong>Warranty information</strong> – Details about our satisfaction guarantee</li>
        </ul>
        <p class="card__content mt-2">
          <strong>After receiving your dentures:</strong> Try them on and inspect the repair. If anything isn't perfect, contact us immediately. We offer a 30-day satisfaction guarantee.
        </p>
      </div>

      <div class="card mb-3" style="background-color: #fef3c7; border-left: 4px solid #f59e0b;">
        <h2 class="card__title">Express Service Available</h2>
        <p class="card__content">
          Need your dentures back urgently? We offer an express service with next-day turnaround for an additional fee. Contact us to arrange express processing.
        </p>
      </div>

      <div class="card mb-3">
        <h2 class="card__title">Frequently Asked Questions</h2>
        
        <div class="faq">
          <div class="faq-item">
            <div class="faq-question">
              How long does the whole process take?
              <span class="faq-icon">+</span>
            </div>
            <div class="faq-answer">
              From when you post your dentures to receiving them back typically takes 5-7 working days total (1-2 days in transit each way, 2-3 days for repair). Express service is available for faster turnaround.
            </div>
          </div>

          <div class="faq-item">
            <div class="faq-question">
              What if my dentures need more work than expected?
              <span class="faq-icon">+</span>
            </div>
            <div class="faq-answer">
              We'll contact you before doing any additional work. You'll receive a revised quote and can choose whether to proceed or have your dentures returned.
            </div>
          </div>

          <div class="faq-item">
            <div class="faq-question">
              Is shipping really included and insured?
              <span class="faq-icon">+</span>
            </div>
            <div class="faq-answer">
              Yes! We provide prepaid, fully insured, and tracked postage both ways at no extra cost. Your dentures are covered throughout their journey.
            </div>
          </div>

          <div class="faq-item">
            <div class="faq-question">
              Can I track my dentures?
              <span class="faq-icon">+</span>
            </div>
            <div class="faq-answer">
              Absolutely. You'll receive tracking numbers for both the journey to us and the return journey. You can track your dentures in real-time.
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-3">
        <h2 style="margin-bottom: 1.5rem;">Ready to Get Started?</h2>
        <p style="font-size: 1.25rem; margin-bottom: 2rem;">
          Simple, secure, and professional denture repair by post
        </p>
        <a href="/pages/services" class="btn btn--primary btn--large" style="margin-right: 1rem;">
          View Our Services
        </a>
        <a href="/pages/contact" class="btn btn--secondary btn--large">
          Have Questions?
        </a>
      </div>
    </div>
  </div>
</div>
