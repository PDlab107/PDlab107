{% comment %}
  Homepage Template
  Features: Hero banner, trust section, how it works, testimonials, CTA
{% endcomment %}

<!-- Hero Section -->
<section class="hero">
  <div class="container">
    <h1 class="hero__title">
      Hassle-Free Acrylic Denture Repair Service by Post
    </h1>
    <p class="hero__subtitle">
      Professional quality repairs for your dentures, delivered straight to your home!<br>
      Trusted by thousands of customers across the UK.
    </p>
    <div class="hero__cta">
      <a href="/pages/services" class="btn btn--large" style="background-color: white; color: var(--color-primary); margin-right: 1rem;">
        Repair My Dentures
      </a>
      <a href="/pages/how-it-works" class="btn btn--large btn--secondary" style="border-color: white; color: white;">
        How It Works
      </a>
    </div>
  </div>
</section>

<!-- Trust Badges Section -->
<section class="trust-badges">
  <div class="trust-badge">
    <div class="trust-badge__icon">⚡</div>
    <h3 class="trust-badge__title">Fast Turnaround</h3>
    <p class="trust-badge__description">2-3 day repair service</p>
  </div>
  <div class="trust-badge">
    <div class="trust-badge__icon">✓</div>
    <h3 class="trust-badge__title">Money-Back Guarantee</h3>
    <p class="trust-badge__description">100% satisfaction guaranteed</p>
  </div>
  <div class="trust-badge">
    <div class="trust-badge__icon">🔒</div>
    <h3 class="trust-badge__title">Fully Insured Postage</h3>
    <p class="trust-badge__description">Safe & secure delivery</p>
  </div>
  <div class="trust-badge">
    <div class="trust-badge__icon">🏆</div>
    <h3 class="trust-badge__title">Expert Technicians</h3>
    <p class="trust-badge__description">Certified professionals</p>
  </div>
</section>

<!-- How It Works Section -->
<section class="section section--large bg-light">
  <div class="container">
    <div class="section__header">
      <h2>How Our Service Works</h2>
      <p class="section__subtitle">Simple, quick, and hassle-free denture repair in 4 easy steps</p>
    </div>

    <div class="steps">
      <div class="step">
        <div class="step__number">1</div>
        <h3 class="step__title">Order Online</h3>
        <p class="step__description">
          Choose your repair service from our website. We offer free quotes based on photos of your dentures.
        </p>
      </div>

      <div class="step">
        <div class="step__number">2</div>
        <h3 class="step__title">Send Your Dentures</h3>
        <p class="step__description">
          Use our prepaid postage service or follow our secure packaging instructions. Fully insured delivery included.
        </p>
      </div>

      <div class="step">
        <div class="step__number">3</div>
        <h3 class="step__title">We Repair</h3>
        <p class="step__description">
          Our expert technicians repair, clean, polish, and sanitize your dentures to the highest standards.
        </p>
      </div>

      <div class="step">
        <div class="step__number">4</div>
        <h3 class="step__title">Receive Your Dentures</h3>
        <p class="step__description">
          Your repaired dentures are posted back to you within 2-3 working days. Fast and reliable service!
        </p>
      </div>
    </div>

    <div class="text-center mt-3">
      <a href="/pages/how-it-works" class="btn btn--primary btn--large">
        Learn More About Our Process
      </a>
    </div>
  </div>
</section>

<!-- Services Overview Section -->
<section class="section section--large">
  <div class="container">
    <div class="section__header">
      <h2>Our Denture Repair Services</h2>
      <p class="section__subtitle">Professional repairs for all types of acrylic dentures</p>
    </div>

    <div class="grid grid--3">
      <div class="card">
        <h3 class="card__title">🔧 Cracked Denture Repair</h3>
        <p class="card__content">
          High-quality repairs for cracked or broken dentures. Includes professional cleaning, polishing, and sanitizing.
        </p>
        <p style="font-size: 1.5rem; font-weight: 700; color: var(--color-primary); margin: 1rem 0;">
          From £50
        </p>
        <a href="/pages/services#cracked-repair" class="btn btn--secondary" style="width: 100%; margin-top: 1rem;">
          View Details
        </a>
      </div>

      <div class="card">
        <h3 class="card__title">🦷 Tooth Replacement</h3>
        <p class="card__content">
          Replace broken or missing teeth on your dentures. Color-matched for a natural appearance.
        </p>
        <p style="font-size: 1.5rem; font-weight: 700; color: var(--color-primary); margin: 1rem 0;">
          From £65
        </p>
        <a href="/pages/services#tooth-replacement" class="btn btn--secondary" style="width: 100%; margin-top: 1rem;">
          View Details
        </a>
      </div>

      <div class="card">
        <h3 class="card__title">✨ Denture Reline</h3>
        <p class="card__content">
          Improve the fit of your dentures with professional relining services for maximum comfort.
        </p>
        <p style="font-size: 1.5rem; font-weight: 700; color: var(--color-primary); margin: 1rem 0;">
          From £80
        </p>
        <a href="/pages/services#reline" class="btn btn--secondary" style="width: 100%; margin-top: 1rem;">
          View Details
        </a>
      </div>
    </div>

    <div class="text-center mt-3">
      <a href="/pages/services" class="btn btn--primary btn--large">
        View All Services
      </a>
    </div>
  </div>
</section>

