{% comment %}
  Services Page Template
  Features: Shopify product integration with Add to Cart functionality
{% endcomment %}

<div class="section section--large">
  <div class="container">
    <div class="section__header">
      <h1>Our Denture Repair Services</h1>
      <p class="section__subtitle">Professional repairs for all types of acrylic dentures</p>
    </div>

    {% comment %} 
      Loop through products in the 'services' collection
      Fallback to static content if collection doesn't exist yet
    {% endcomment %}
    
    {% if collections['services'] and collections['services'].products.size > 0 %}
      {% comment %} Dynamic product display from Shopify {% endcomment %}
      {% for product in collections['services'].products %}
        <div id="{{ product.handle }}" class="card mb-3" style="scroll-margin-top: 100px;">
          <div class="grid grid--2" style="align-items: center;">
            {% if forloop.index == 2 or forloop.index == 4 %}
              {% comment %} Alternate layout - image first {% endcomment %}
              <div style="background-color: var(--color-background-light); padding: 2rem; border-radius: 12px; text-align: center;">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | img_url: '400x' }}" alt="{{ product.title }}" style="max-width: 100%; border-radius: 8px;">
                {% else %}
                  <div style="font-size: 6rem; margin-bottom: 1rem;">🦷</div>
                  <p style="font-size: 1.125rem; color: var(--color-text-light);">
                    <strong>{{ product.title }}</strong><br>
                    Professional service
                  </p>
                {% endif %}
              </div>
            {% endif %}
            
            <div>
              <h2 class="card__title">{{ product.title }}</h2>
              <div class="card__content">
                {{ product.description }}
              </div>
              
              <div style="margin-top: 2rem;">
                <p style="font-size: 2rem; font-weight: 700; color: var(--color-primary); margin-bottom: 1rem;">
                  {{ product.price | money }}
                </p>
                
                {% comment %} Add to Cart Form {% endcomment %}
                <form action="/cart/add" method="post" class="add-to-cart-form">
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  
                  {% if product.variants.size > 1 %}
                    <div class="form-group" style="margin-bottom: 1rem;">
                      <label class="form-label">Select Option:</label>
                      <select name="id" class="form-input">
                        {% for variant in product.variants %}
                          <option value="{{ variant.id }}" {% if variant.available == false %}disabled{% endif %}>
                            {{ variant.title }} - {{ variant.price | money }}
                            {% unless variant.available %} (Sold Out){% endunless %}
                          </option>
                        {% endfor %}
                      </select>
                    </div>
                  {% endif %}
                  
                  {% comment %} Optional: Add special instructions field {% endcomment %}
                  <div class="form-group" style="margin-bottom: 1rem;">
                    <label class="form-label">Special Instructions (Optional):</label>
                    <textarea name="properties[Instructions]" class="form-textarea" placeholder="Any specific requirements or notes about your repair..." style="min-height: 80px;"></textarea>
                  </div>
                  
                  <button type="submit" class="btn btn--primary add-to-cart-btn" style="width: 100%;">
                    {% if product.selected_or_first_available_variant.available %}
                      Add to Cart
                    {% else %}
                      Sold Out
                    {% endif %}
                  </button>
                </form>
              </div>
            </div>
            
            {% if forloop.index != 2 and forloop.index != 4 %}
              {% comment %} Standard layout - image last {% endcomment %}
              <div style="background-color: var(--color-background-light); padding: 2rem; border-radius: 12px; text-align: center;">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | img_url: '400x' }}" alt="{{ product.title }}" style="max-width: 100%; border-radius: 8px;">
                {% else %}
                  <div style="font-size: 6rem; margin-bottom: 1rem;">🦷</div>
                  <p style="font-size: 1.125rem; color: var(--color-text-light);">
                    <strong>{{ product.title }}</strong><br>
                    Professional service
                  </p>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
      
    {% else %}
      {% comment %} Fallback static content with Add to Cart forms {% endcomment %}

    <!-- Service 1: Cracked Denture Repair -->
    <div id="cracked-repair" class="card mb-3" style="scroll-margin-top: 100px;">
