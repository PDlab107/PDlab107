{% comment %}
  Services Page Template
  Features: All denture repair services with pricing, descriptions, and image upload
{% endcomment %}

<div class="section section--large">
  <div class="container">
    <div class="section__header">
      <h1>Our Denture Repair Services</h1>
      <p class="section__subtitle">Professional repairs for all types of acrylic dentures</p>
    </div>

    <!-- Service 1: Cracked Denture Repair -->
    <div id="cracked-repair" class="card mb-3" style="scroll-margin-top: 100px;">
      <div class="grid grid--2" style="align-items: center;">
        <div>
          <h2 class="card__title">🔧 Cracked Denture Repair</h2>
          <p class="card__content">
            Has your denture cracked or broken? Don't worry – we can fix it! Our expert technicians specialize in repairing cracks, breaks, and fractures in acrylic dentures.
          </p>
          <p class="card__content">
            <strong>What's included:</strong>
          </p>
          <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
            <li>Professional structural repair using high-quality bonding materials</li>
            <li>Reinforcement to prevent future cracks</li>
            <li>Professional cleaning and sanitizing</li>
            <li>Polishing for a natural finish</li>
            <li>Quality inspection before return</li>
          </ul>
          <div style="margin-top: 2rem;">
            <p style="font-size: 2rem; font-weight: 700; color: var(--color-primary); margin-bottom: 1rem;">
              From £50
            </p>
            <a href="/pages/contact" class="btn btn--primary">Get a Free Quote</a>
          </div>
        </div>
        <div style="background-color: var(--color-background-light); padding: 2rem; border-radius: 12px; text-align: center;">
          <div style="font-size: 6rem; margin-bottom: 1rem;">🦷</div>
          <p style="font-size: 1.125rem; color: var(--color-text-light);">
            <strong>Before & After:</strong><br>
            Send us photos of your damaged dentures for an accurate quote
          </p>
        </div>
      </div>
    </div>

    <!-- Service 2: Tooth Replacement -->
    <div id="tooth-replacement" class="card mb-3" style="scroll-margin-top: 100px;">
      <div class="grid grid--2" style="align-items: center;">
        <div style="background-color: var(--color-background-light); padding: 2rem; border-radius: 12px; text-align: center;">
          <div style="font-size: 6rem; margin-bottom: 1rem;">🦷</div>
          <p style="font-size: 1.125rem; color: var(--color-text-light);">
            <strong>Perfect Color Match:</strong><br>
            We ensure your new tooth matches the rest of your dentures
          </p>
        </div>
        <div>
          <h2 class="card__title">🦷 Tooth Replacement</h2>
          <p class="card__content">
            Missing or broken teeth on your dentures? We can replace individual teeth or multiple teeth, ensuring they match perfectly with your existing dentures.
          </p>
          <p class="card__content">
            <strong>What's included:</strong>
          </p>
          <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
            <li>Replacement of broken or missing teeth</li>
            <li>Perfect color and size matching</li>
            <li>Secure bonding for long-lasting results</li>
            <li>Professional polishing and finishing</li>
            <li>Complete sanitization</li>
          </ul>
          <div style="margin-top: 2rem;">
            <p style="font-size: 2rem; font-weight: 700; color: var(--color-primary); margin-bottom: 1rem;">
              From £65 per tooth
            </p>
            <a href="/pages/contact" class="btn btn--primary">Get a Free Quote</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Service 3: Denture Reline -->
    <div id="reline" class="card mb-3" style="scroll-margin-top: 100px;">
      <div class="grid grid--2" style="align-items: center;">
        <div>
          <h2 class="card__title">✨ Denture Reline</h2>
          <p class="card__content">
            Over time, your gums and bone structure can change, causing dentures to become loose or uncomfortable. A professional reline restores the fit for maximum comfort.
          </p>
          <p class="card__content">
            <strong>What's included:</strong>
          </p>
          <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
            <li>Complete reline of denture base</li>
            <li>Improved fit and comfort</li>
            <li>Better stability and retention</li>
            <li>Professional cleaning and polishing</li>
            <li>Reduced movement while eating and speaking</li>
          </ul>
          <div style="margin-top: 2rem;">
            <p style="font-size: 2rem; font-weight: 700; color: var(--color-primary); margin-bottom: 1rem;">
              From £80
            </p>
            <a href="/pages/contact" class="btn btn--primary">Get a Free Quote</a>
          </div>
        </div>
        <div style="background-color: var(--color-background-light); padding: 2rem; border-radius: 12px; text-align: center;">
          <div style="font-size: 6rem; margin-bottom: 1rem;">😊</div>
          <p style="font-size: 1.125rem; color: var(--color-text-light);">
            <strong>Improved Comfort:</strong><br>
            Reline your dentures for a better, more secure fit
          </p>
        </div>
      </div>
    </div>

    <!-- Service 4: Professional Cleaning & Polishing -->
    <div id="cleaning" class="card mb-3" style="scroll-margin-top: 100px;">
      <div class="grid grid--2" style="align-items: center;">
        <div style="background-color: var(--color-background-light); padding: 2rem; border-radius: 12px; text-align: center;">
          <div style="font-size: 6rem; margin-bottom: 1rem;">✨</div>
          <p style="font-size: 1.125rem; color: var(--color-text-light);">
            <strong>Like New Again:</strong><br>
            Professional cleaning removes stains and buildup
          </p>
        </div>
        <div>
          <h2 class="card__title">✨ Professional Cleaning & Polishing</h2>
          <p class="card__content">
            Even with regular home cleaning, dentures can develop stains, tartar, and discoloration. Our professional cleaning service restores their appearance.
          </p>
          <p class="card__content">
            <strong>What's included:</strong>
          </p>
          <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
            <li>Deep professional cleaning</li>
            <li>Stain removal</li>
            <li>Tartar and plaque removal</li>
            <li>High-gloss polishing</li>
            <li>Complete sanitization</li>
          </ul>
          <div style="margin-top: 2rem;">
            <p style="font-size: 2rem; font-weight: 700; color: var(--color-primary); margin-bottom: 1rem;">
              From £35
            </p>
            <a href="/pages/contact" class="btn btn--primary">Get a Free Quote</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Service 5: Denture Adjustments -->
    <div id="adjustments" class="card mb-3" style="scroll-margin-top: 100px;">
      <div class="grid grid--2" style="align-items: center;">
        <div>
          <h2 class="card__title">🔨 Denture Adjustments</h2>
          <p class="card__content">
            Are your dentures causing sore spots or discomfort? We can make precise adjustments to eliminate pressure points and improve fit.
          </p>
          <p class="card__content">
            <strong>What's included:</strong>
          </p>
          <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
            <li>Precise adjustment of pressure points</li>
            <li>Elimination of sore spots</li>
            <li>Improved comfort during wear</li>
            <li>Professional smoothing and finishing</li>
            <li>Quality inspection</li>
          </ul>
          <div style="margin-top: 2rem;">
            <p style="font-size: 2rem; font-weight: 700; color: var(--color-primary); margin-bottom: 1rem;">
              From £40
            </p>
            <a href="/pages/contact" class="btn btn--primary">Get a Free Quote</a>
          </div>
        </div>
        <div style="background-color: var(--color-background-light); padding: 2rem; border-radius: 12px; text-align: center;">
          <div style="font-size: 6rem; margin-bottom: 1rem;">😌</div>
          <p style="font-size: 1.125rem; color: var(--color-text-light);">
            <strong>No More Discomfort:</strong><br>
            Custom adjustments for a perfect fit
          </p>
        </div>
      </div>
    </div>

    <!-- Image Upload Section -->
    <div class="card mb-3" style="background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); border: 2px solid var(--color-primary);">
      <h2 class="card__title" style="text-align: center; color: var(--color-primary);">📸 Get an Instant Quote</h2>
      <p class="card__content" style="text-align: center; font-size: 1.25rem;">
        Upload photos of your dentures and tell us what needs repairing. We'll provide a free, no-obligation quote within 24 hours.
      </p>
      
      <form action="/pages/contact" method="get" style="max-width: 600px; margin: 2rem auto 0;">
        <div class="form-group">
          <label class="form-label">Your Name</label>
          <input type="text" name="name" class="form-input" placeholder="Enter your name" required>
        </div>
        
        <div class="form-group">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" class="form-input" placeholder="your.email@example.com" required>
        </div>
        
        <div class="form-group">
          <label class="form-label">Phone Number (Optional)</label>
          <input type="tel" name="phone" class="form-input" placeholder="+44 123 456 7890">
        </div>
        
        <div class="form-group">
          <label class="form-label">Upload Photos of Your Dentures</label>
          <input type="file" accept="image/*" multiple class="form-input" style="padding: 1rem;">
          <p style="font-size: 1rem; color: var(--color-text-light); margin-top: 0.5rem;">
            You can upload multiple photos. Clear images help us provide an accurate quote.
          </p>
        </div>
        
        <div class="form-group">
          <label class="form-label">Describe the Problem</label>
          <textarea name="description" class="form-textarea" placeholder="Tell us what's wrong with your dentures..." required></textarea>
        </div>
        
        <button type="submit" class="btn btn--primary btn--large" style="width: 100%;">
          Get Free Quote
        </button>
      </form>
    </div>

    <!-- Service Comparison Table -->
    <div class="card mb-3">
      <h2 class="card__title" style="text-align: center;">Service Comparison</h2>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; margin-top: 2rem;">
          <thead>
            <tr style="background-color: var(--color-primary); color: white;">
              <th style="padding: 1.25rem; text-align: left; font-size: 1.125rem; border: 1px solid white;">Service</th>
              <th style="padding: 1.25rem; text-align: center; font-size: 1.125rem; border: 1px solid white;">Starting Price</th>
              <th style="padding: 1.25rem; text-align: center; font-size: 1.125rem; border: 1px solid white;">Turnaround</th>
              <th style="padding: 1.25rem; text-align: center; font-size: 1.125rem; border: 1px solid white;">Express Available</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 1.25rem; font-size: 1.125rem;">Cracked Denture Repair</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem; font-weight: 600; color: var(--color-primary);">£50</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem;">2-3 days</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem;">✓</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 1.25rem; font-size: 1.125rem;">Tooth Replacement</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem; font-weight: 600; color: var(--color-primary);">£65</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem;">2-3 days</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem;">✓</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 1.25rem; font-size: 1.125rem;">Denture Reline</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem; font-weight: 600; color: var(--color-primary);">£80</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem;">3-4 days</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem;">✓</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 1.25rem; font-size: 1.125rem;">Professional Cleaning</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem; font-weight: 600; color: var(--color-primary);">£35</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem;">1-2 days</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem;">✓</td>
            </tr>
            <tr>
              <td style="padding: 1.25rem; font-size: 1.125rem;">Denture Adjustments</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem; font-weight: 600; color: var(--color-primary);">£40</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem;">1-2 days</td>
              <td style="padding: 1.25rem; text-align: center; font-size: 1.125rem;">✓</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p style="font-size: 1rem; color: var(--color-text-light); margin-top: 1.5rem; text-align: center;">
        <strong>Note:</strong> All prices include free, insured postage both ways. Express service available for an additional £20.
      </p>
    </div>

    <!-- Why Choose Us for Services -->
    <div class="card mb-3" style="background-color: var(--color-background-light);">
      <h2 class="card__title" style="text-align: center;">Why Choose Our Services?</h2>
      <div class="grid grid--4 mt-2">
        <div style="text-align: center;">
          <div style="font-size: 3rem; margin-bottom: 0.5rem;">✓</div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem;">Quality Guarantee</h3>
          <p style="font-size: 1rem; color: var(--color-text-light);">100% satisfaction or money back</p>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 3rem; margin-bottom: 0.5rem;">🚚</div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem;">Free Shipping</h3>
          <p style="font-size: 1rem; color: var(--color-text-light);">Fully insured both ways</p>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 3rem; margin-bottom: 0.5rem;">⚡</div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem;">Fast Service</h3>
          <p style="font-size: 1rem; color: var(--color-text-light);">2-3 day turnaround</p>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 3rem; margin-bottom: 0.5rem;">🏆</div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem;">Expert Team</h3>
          <p style="font-size: 1rem; color: var(--color-text-light);">Certified technicians</p>
        </div>
      </div>
    </div>

    <div class="text-center mt-3">
      <h2 style="margin-bottom: 1.5rem;">Ready to Repair Your Dentures?</h2>
      <p style="font-size: 1.25rem; margin-bottom: 2rem;">
        Get started with a free quote today
      </p>
      <a href="/pages/contact" class="btn btn--primary btn--large" style="margin-right: 1rem;">
        Get Free Quote
      </a>
      <a href="/pages/how-it-works" class="btn btn--secondary btn--large">
        How It Works
      </a>
    </div>
  </div>
</div>
