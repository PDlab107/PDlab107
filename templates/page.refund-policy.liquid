{% comment %}
  Refund Policy Page Template
{% endcomment %}

<div class="section section--large">
  <div class="container container--narrow">
    <h1>Refund Policy</h1>
    <p style="font-size: 1.125rem; color: var(--color-text-light); margin-bottom: 3rem;">
      Last updated: {{ 'now' | date: '%B %d, %Y' }}
    </p>

    <div class="card mb-2">
      <h2 class="card__title">30-Day Satisfaction Guarantee</h2>
      <p class="card__content">
        We stand behind the quality of our work. If you're not completely satisfied with your denture repair, we offer a 30-day satisfaction guarantee from the date you receive your repaired dentures.
      </p>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Refund Eligibility</h2>
      <p class="card__content">
        You may be eligible for a refund if:
      </p>
      <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
        <li>The repair does not meet the agreed specifications</li>
        <li>The dentures were damaged during our repair process</li>
        <li>We are unable to complete the repair as promised</li>
        <li>You are not satisfied with the quality of our work</li>
      </ul>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Refund Process</h2>
      <p class="card__content">
        To request a refund:
      </p>
      <ol style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
        <li>Contact us within 30 days of receiving your dentures</li>
        <li>Explain the reason for your dissatisfaction</li>
        <li>Provide photos if applicable</li>
        <li>Return the dentures to us (we'll provide prepaid postage)</li>
      </ol>
      <p class="card__content" style="margin-top: 1.5rem;">
        We'll review your request within 2-3 business days. If approved, your refund will be processed within 5-10 business days to your original payment method.
      </p>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Re-work Policy</h2>
      <p class="card__content">
        In most cases, we prefer to re-work the repair to ensure your complete satisfaction. This is often faster than a refund and ensures you get the dentures you need. Re-work is provided at no additional cost.
      </p>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Non-Refundable Items</h2>
      <p class="card__content">
        The following are not eligible for refunds:
      </p>
      <ul style="font-size: 1.125rem; line-height: 2; margin-left: 2rem;">
        <li>Completed work that meets the agreed specifications</li>
        <li>Damage occurring after delivery to you</li>
        <li>Repairs rejected after more than 30 days</li>
        <li>Custom quotes where work has been completed</li>
      </ul>
    </div>

    <div class="card mb-2">
      <h2 class="card__title">Contact Us</h2>
      <p class="card__content">
        For refund requests or questions about our refund policy:
      </p>
      <p class="card__content">
        Email: <a href="mailto:refunds@denturefixnow.co.uk">refunds@denturefixnow.co.uk</a><br>
        Phone: <a href="tel:+441234567890">+44 123 456 7890</a>
      </p>
    </div>
  </div>
</div>
